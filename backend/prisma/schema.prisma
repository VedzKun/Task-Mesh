// This is your Prisma schema file.
// Task-Mesh: Distributed Job Scheduler
// Designed for PostgreSQL with SKIP LOCKED for atomic job claiming.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         UserRole  @default(MEMBER)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  projects     Project[]

  @@map("users")
}

enum UserRole {
  ADMIN
  MEMBER
}

// ─────────────────────────────────────────────
// PROJECTS & API KEYS
// ─────────────────────────────────────────────
model Project {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  apiKeyHash  String   @unique @map("api_key_hash")
  apiKeyPrefix String  @map("api_key_prefix") // first 8 chars for display
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  queues      Queue[]

  @@index([userId])
  @@map("projects")
}

// ─────────────────────────────────────────────
// RETRY POLICIES
// ─────────────────────────────────────────────
model RetryPolicy {
  id          String          @id @default(uuid())
  name        String
  strategy    RetryStrategy   @default(EXPONENTIAL)
  maxAttempts Int             @default(3) @map("max_attempts")
  baseDelayMs Int             @default(1000) @map("base_delay_ms")   // ms
  maxDelayMs  Int             @default(60000) @map("max_delay_ms")   // 60s cap
  multiplier  Float           @default(2.0)   // for exponential
  createdAt   DateTime        @default(now()) @map("created_at")

  queues      Queue[]
  jobs        Job[]

  @@map("retry_policies")
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

// ─────────────────────────────────────────────
// QUEUES
// ─────────────────────────────────────────────
model Queue {
  id               String   @id @default(uuid())
  projectId        String   @map("project_id")
  name             String
  description      String?
  priority         Int      @default(5)           // 1=lowest, 10=highest
  concurrencyLimit Int      @default(5) @map("concurrency_limit")
  rateLimitPerMin  Int?     @map("rate_limit_per_min") // bonus: rate limiting
  isPaused         Boolean  @default(false) @map("is_paused")
  retryPolicyId    String?  @map("retry_policy_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  retryPolicy      RetryPolicy? @relation(fields: [retryPolicyId], references: [id])
  jobs             Job[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([isPaused, priority])
  @@map("queues")
}

// ─────────────────────────────────────────────
// JOBS
// ─────────────────────────────────────────────
model Job {
  id             String    @id @default(uuid())
  queueId        String    @map("queue_id")
  name           String
  payload        Json      @default("{}")
  status         JobStatus @default(QUEUED)

  // Scheduling
  jobType        JobType   @default(IMMEDIATE) @map("job_type")
  runAt          DateTime  @default(now()) @map("run_at")         // when to run
  cronExpression String?   @map("cron_expression")                // for CRON jobs
  nextRunAt      DateTime? @map("next_run_at")                    // next scheduled trigger

  // Priority & retry
  priority       Int       @default(5)
  maxRetries     Int       @default(3) @map("max_retries")
  attempts       Int       @default(0)
  retryPolicyId  String?   @map("retry_policy_id")
  lastError      String?   @map("last_error")

  // Atomic locking (worker claiming)
  lockedAt       DateTime? @map("locked_at")
  lockedBy       String?   @map("locked_by")                     // worker id

  // Batch support
  batchId        String?   @map("batch_id")

  // Workflow dependencies (bonus)
  dependsOnJobId String?   @map("depends_on_job_id")

  // Idempotency
  idempotencyKey String?   @unique @map("idempotency_key")

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  completedAt    DateTime? @map("completed_at")

  queue          Queue        @relation(fields: [queueId], references: [id], onDelete: Cascade)
  retryPolicy    RetryPolicy? @relation(fields: [retryPolicyId], references: [id])
  dependsOn      Job?         @relation("JobDependency", fields: [dependsOnJobId], references: [id])
  dependents     Job[]        @relation("JobDependency")
  executions     JobExecution[]
  dlqEntry       DeadLetterQueue?
  logs           JobLog[]

  // Critical composite index for the worker poll query:
  // WHERE status = 'QUEUED' AND run_at <= NOW() ORDER BY priority DESC, run_at ASC
  @@index([status, runAt])
  @@index([status, priority, runAt])
  @@index([queueId, status])
  @@index([batchId])
  @@index([cronExpression])
  @@map("jobs")
}

enum JobStatus {
  QUEUED
  SCHEDULED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  DLQ
}

enum JobType {
  IMMEDIATE
  DELAYED
  SCHEDULED
  CRON
  BATCH
}

// ─────────────────────────────────────────────
// JOB EXECUTIONS (execution log per attempt)
// ─────────────────────────────────────────────
model JobExecution {
  id          String          @id @default(uuid())
  jobId       String          @map("job_id")
  workerId    String          @map("worker_id")
  attempt     Int             @default(1)
  status      ExecutionStatus @default(RUNNING)
  startedAt   DateTime        @default(now()) @map("started_at")
  completedAt DateTime?       @map("completed_at")
  durationMs  Int?            @map("duration_ms")
  errorMessage String?        @map("error_message")
  errorStack  String?         @map("error_stack")
  resultData  Json?           @map("result_data")
  createdAt   DateTime        @default(now()) @map("created_at")

  job         Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker      Worker  @relation(fields: [workerId], references: [id])

  @@index([jobId])
  @@index([workerId])
  @@index([status, startedAt])
  @@map("job_executions")
}

enum ExecutionStatus {
  RUNNING
  SUCCEEDED
  FAILED
  TIMED_OUT
}

// ─────────────────────────────────────────────
// JOB LOGS (structured logs per job)
// ─────────────────────────────────────────────
model JobLog {
  id        String   @id @default(uuid())
  jobId     String   @map("job_id")
  level     LogLevel @default(INFO)
  message   String
  meta      Json?
  timestamp DateTime @default(now())

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, timestamp])
  @@map("job_logs")
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

// ─────────────────────────────────────────────
// WORKERS
// ─────────────────────────────────────────────
model Worker {
  id            String       @id @default(uuid())
  hostname      String
  pid           Int
  status        WorkerStatus @default(IDLE)
  concurrency   Int          @default(5)
  currentJobs   Int          @default(0) @map("current_jobs")
  lastHeartbeat DateTime     @default(now()) @map("last_heartbeat")
  registeredAt  DateTime     @default(now()) @map("registered_at")
  metadata      Json?        // e.g. { "version": "1.0", "queues": ["default"] }

  executions    JobExecution[]
  heartbeats    WorkerHeartbeat[]

  @@index([status, lastHeartbeat])
  @@map("workers")
}

enum WorkerStatus {
  IDLE
  BUSY
  DRAINING
  OFFLINE
}

// ─────────────────────────────────────────────
// WORKER HEARTBEATS (historical)
// ─────────────────────────────────────────────
model WorkerHeartbeat {
  id          String   @id @default(uuid())
  workerId    String   @map("worker_id")
  currentJobs Int      @map("current_jobs")
  memoryMb    Float?   @map("memory_mb")
  cpuPercent  Float?   @map("cpu_percent")
  timestamp   DateTime @default(now())

  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, timestamp])
  @@map("worker_heartbeats")
}

// ─────────────────────────────────────────────
// DEAD LETTER QUEUE
// ─────────────────────────────────────────────
model DeadLetterQueue {
  id           String   @id @default(uuid())
  jobId        String   @unique @map("job_id")
  queueId      String   @map("queue_id")
  reason       String
  originalPayload Json  @map("original_payload")
  attempts     Int
  failedAt     DateTime @default(now()) @map("failed_at")
  resolvedAt   DateTime? @map("resolved_at")
  resolvedBy   String?   @map("resolved_by")

  job          Job      @relation(fields: [jobId], references: [id])

  @@index([queueId, failedAt])
  @@map("dead_letter_queue")
}
